<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Boards_WP.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Boards_WP"
    xmlns:views="using:Boards_WP.Views"
    xmlns:pages="using:Boards_WP.Views.Pages"
    Title="Boards_WP">

    <Grid x:Name="RootGrid" Background="{x:Bind MainViewModel.AppThemeBrush, Mode=OneWay}">
        
        
        <Frame x:Name="LoginFrame" x:FieldModifier="public" Canvas.ZIndex="10" />

        <Grid x:Name="MainLayout" 
            Visibility="{x:Bind BoolToVis(MainViewModel.IsLoggedIn), Mode=OneWay}">
            
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <views:HeaderView Grid.Row="0" />

            <Grid Grid.Row="1" Margin="10,0,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/> 
                    <ColumnDefinition Width="*"/>   
                    <ColumnDefinition Width="260"/> 
                </Grid.ColumnDefinitions>

                <views:CommunityBarView Grid.Column="0"/>

                <Grid Grid.Column="1" Margin="4">
                    <Frame x:Name="ContentFrame" x:FieldModifier="public"/>
                </Grid>

                <views:NotificationsView Grid.Column="2"/>
            </Grid>
        </Grid>
    </Grid>
</Window>