<UserControl
    x:Class="Boards_WP.Views.CommentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Boards_WP.Views">

    <Grid Margin="{x:Bind GetIndentMargin(CommentData.Indentation), Mode=OneWay}" Padding="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Width="2" Background="white" Margin="0,5,15,5"
                Visibility="{x:Bind GetLineVisibility(CommentData.Indentation), Mode=OneWay}" CornerRadius="1"/>

        <StackPanel Grid.Column="1">
            <Border Background="White" CornerRadius="12" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel Spacing="5">
                    <TextBlock Text="{x:Bind CommentData.Owner.Username}" FontWeight="Bold" Foreground="#6A67E1"/>
                    <TextBlock Text="{x:Bind ViewModel.CommentText, Mode=OneWay}" TextWrapping="Wrap"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="15" Margin="0,5,0,0"
                                Visibility="{x:Bind ViewModel.ActionButtonsVisibility, Mode=OneWay}">
    
                        <Button Command="{x:Bind ViewModel.DeleteCommentCommand}" 
                                Visibility="{x:Bind ViewModel.DeleteButtonVisibility, Mode=OneWay}" 
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="Red"/>
                                <TextBlock Text="delete" FontSize="12" Foreground="Red"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{x:Bind ViewModel.ToggleShareCommand}" Background="Transparent" BorderThickness="0" Padding="0">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE72D;" FontSize="14" Foreground="#6A67E1"/>
                                <TextBlock Text="share" FontSize="12" Foreground="#6A67E1"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{x:Bind ViewModel.ToggleReplyCommand}" Background="Transparent" BorderThickness="0" Padding="0">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE8BD;" FontSize="14" Foreground="#6A67E1"/>
                                <TextBlock Text="reply" FontSize="12" Foreground="#6A67E1"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Visibility="{x:Bind ViewModel.IsShareVisible, Mode=OneWay}" 
                    Margin="20,10,0,0" Padding="10" Background="White" CornerRadius="10" BorderBrush="#6A67E1" BorderThickness="1">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ComboBox ItemsSource="{x:Bind ViewModel.HardcodedChats}"
                                  SelectedItem="{x:Bind ViewModel.SelectedChatName, Mode=TwoWay}"
                                  PlaceholderText="Select Chat" Width="150"/>
                        <TextBox Text="{x:Bind ViewModel.SelectedChatName, Mode=OneWay}" 
                                 IsReadOnly="True" Width="120" Background="#F9F9F9" BorderThickness="0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Send" Command="{x:Bind ViewModel.SendShareCommand}"
                            Background="#6A67E1" Foreground="White" Margin="10,0,0,0" CornerRadius="5"/>
                </Grid>
            </Border>

            <StackPanel Visibility="{x:Bind ViewModel.IsReplyAreaVisible, Mode=OneWay}" Margin="40,10,0,0" Spacing="8">
                <TextBox Text="{x:Bind ViewModel.ReplyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         PlaceholderText="Write a reply..." AcceptsReturn="True"/>
                <Button Content="Post Reply" Command="{x:Bind ViewModel.SubmitReplyCommand}" 
                        HorizontalAlignment="Right" Background="white" Foreground="White" CornerRadius="8"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>