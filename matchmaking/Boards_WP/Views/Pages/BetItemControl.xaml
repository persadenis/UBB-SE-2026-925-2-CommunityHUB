<UserControl
    x:Class="Boards_WP.Views.BetItemControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Boards_WP.Views"
    xmlns:viewmodels="using:Boards_WP.ViewModels"
    xmlns:models="using:Boards_WP.Data.Models">

    <Border Background="White" CornerRadius="12" Margin="0,0,0,16" Padding="20" 
            BorderBrush="#E0E0FF" BorderThickness="1">
        <StackPanel Spacing="15">
            <TextBlock TextWrapping="Wrap" FontSize="15" LineHeight="22">
                <Run Text="Someone will create a "/>
                <Run Text="{x:Bind ViewModel.BetData.Type, Mode=OneWay}" FontWeight="Bold"/>
                <Run Text=" in "/>
                <Run Text="{x:Bind ViewModel.BetData.BetCommunity.Name, Mode=OneWay}" FontWeight="Bold"/>
                <Run Text=" which contains the expression "/>
                <Run Text="{x:Bind ViewModel.BetData.Expression, Mode=OneWay}" Foreground="#6A67E1" FontWeight="Bold"/>
                <Run Text=" between "/>
                <Run Text="{x:Bind ViewModel.BetData.StartingTime, Mode=OneWay}"/>
                <Run Text=" and "/>
                <Run Text="{x:Bind ViewModel.BetData.EndingTime, Mode=OneWay}"/>
                <Run Text="."/>
            </TextBlock>

            <Border Background="#F0F0F0" Height="1" HorizontalAlignment="Stretch"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="25">
                    <StackPanel>
                        <TextBlock Text="Yes Odds" FontSize="11" Foreground="Gray"/>
                        <TextBlock Text="{x:Bind ViewModel.YesOdds, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" Foreground="Green"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="No Odds" FontSize="11" Foreground="Gray"/>
                        <TextBlock Text="{x:Bind ViewModel.NoOdds, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" Foreground="Red"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Time left to bet" FontSize="11" Foreground="Gray" HorizontalAlignment="Right"/>
                    <TextBlock Text="{x:Bind ViewModel.TimeLeft, Mode=OneWay}" FontSize="16" FontWeight="Bold" Foreground="#6A67E1"/>
                </StackPanel>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Bet Yes"
                        Command="{x:Bind ViewModel.BetYesCommand, Mode=OneWay}"
                        Background="#E7F8EE"
                        Foreground="Green"/>
                <Button Content="Bet No"
                        Command="{x:Bind ViewModel.BetNoCommand, Mode=OneWay}"
                        Background="#FDEDED"
                        Foreground="Red"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>