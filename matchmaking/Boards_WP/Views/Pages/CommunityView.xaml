<Page
    x:Class="Boards_WP.Views.Pages.CommunityView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Boards_WP.Data.Models"
    xmlns:views="using:Boards_WP.Views"
    xmlns:viewmodels="using:Boards_WP.ViewModels"
    Background="Transparent">

    <Grid>
        <ScrollViewer>
            <StackPanel Spacing="15" Margin="0,0,0,20">

                <Grid>
                    <!-- 1. Banner Image Element (Bottom Layer) -->
                    <Border Height="200" VerticalAlignment="Top" Background="#F0F0F0" CornerRadius="0,0,15,15">
                        <Image Source="{x:Bind ViewModel.BannerImage, Mode=OneWay}" Stretch="UniformToFill"/>
                    </Border>

                    <!-- 2. Header Content Card (Middle Layer) 
                            Overlaps the Banner exactly by 50px using Margin -->
                    <Border Background="White" CornerRadius="12" Margin="20,150,20,0" Padding="15,20,15,20" BorderBrush="#E0E0FF" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!-- Gap for the Avatar to sit above cleanly -->
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.CurrentCommunity.Name, Mode=OneWay}"
                                           FontSize="26" FontWeight="Bold" Foreground="Black" TextWrapping="Wrap"/>

                                <TextBlock Text="{x:Bind ViewModel.MemberCountText, Mode=OneWay}"
                                           FontSize="14" Foreground="Gray" Margin="0,5,0,12"/>

                                <!-- ScrollViewer prevents buttons from ever pushing out of bounds and becoming unclickable visually -->
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <StackPanel Orientation="Horizontal" Spacing="8" Padding="0,0,0,10">

                                        <Button Content="Join Community"
                                                Command="{x:Bind ViewModel.JoinCommand}"
                                                Background="{x:Bind ViewModel.MainViewModel.VividThemeBrush, Mode=OneWay}" 
                                                Foreground="White" CornerRadius="8"
                                                Visibility="{x:Bind ViewModel.JoinButtonVisibility, Mode=OneWay}"/>

                                        <StackPanel Orientation="Horizontal" Spacing="8"
                                                    Visibility="{x:Bind ViewModel.MemberActionsVisibility, Mode=OneWay}">

                                            <Button Content="Create Post"
                                                Command="{x:Bind ViewModel.CreatePostCommand}"
                                                Background="White" 
                                                BorderBrush="{x:Bind ViewModel.MainViewModel.VividThemeBrush, Mode=OneWay}" BorderThickness="1" 
                                                Foreground="{x:Bind ViewModel.MainViewModel.VividThemeBrush, Mode=OneWay}" CornerRadius="8">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Gray"/>
                                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Gray"/>
                                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{x:Bind ViewModel.MainViewModel.VividThemeColor, Mode=OneWay}"/>
                                                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="{x:Bind ViewModel.MainViewModel.VividThemeColor, Mode=OneWay}"/>
                                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{x:Bind ViewModel.MainViewModel.VividThemeColor, Mode=OneWay}"/>
                                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{x:Bind ViewModel.MainViewModel.VividThemeColor, Mode=OneWay}"/>
                                                </Button.Resources>
                                            </Button>

                                            <Button Content="Edit Community"
                                                Command="{x:Bind ViewModel.EditCommunityCommand}"
                                                Background="White" 
                                                BorderBrush="{x:Bind ViewModel.MainViewModel.VividThemeBrush, Mode=OneWay}" BorderThickness="1" 
                                                Foreground="{x:Bind ViewModel.MainViewModel.VividThemeBrush, Mode=OneWay}" CornerRadius="8"
                                                Visibility="{x:Bind ViewModel.EditButtonVisibility, Mode=OneWay}">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Gray"/>
                                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Gray"/>
                                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{x:Bind ViewModel.MainViewModel.VividThemeColor, Mode=OneWay}"/>
                                                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="{x:Bind ViewModel.MainViewModel.VividThemeColor, Mode=OneWay}"/>
                                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{x:Bind ViewModel.MainViewModel.VividThemeColor, Mode=OneWay}"/>
                                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{x:Bind ViewModel.MainViewModel.VividThemeColor, Mode=OneWay}"/>
                                                </Button.Resources>
                                            </Button>

                                            <Button Content="Leave Community"
                                                    Command="{x:Bind ViewModel.LeaveCommand}"
                                                    Background="#D32F2F" 
                                                    Foreground="Black" BorderBrush="Black" BorderThickness="1" CornerRadius="8">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#944141"/>
                                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#944141"/>
                                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Black"/>
                                                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Black"/>
                                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{x:Bind ViewModel.MainViewModel.VividThemeColor, Mode=OneWay}"/>
                                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{x:Bind ViewModel.MainViewModel.VividThemeColor, Mode=OneWay}"/>
                                                </Button.Resources>
                                            </Button>
                                        </StackPanel>

                                    </StackPanel>
                                </ScrollViewer>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 3. Avatar Base (Top Layer)
                            Sits floating completely freely over the layout so it is never clipped/cut by boundaries! -->
                    <PersonPicture ProfilePicture="{x:Bind ViewModel.ProfileImage, Mode=OneWay}"
                                   DisplayName="{x:Bind ViewModel.CurrentCommunity.Name, Mode=OneWay}"
                                   Height="100" Width="100" BorderBrush="White" BorderThickness="3" 
                                   VerticalAlignment="Top" HorizontalAlignment="Left" Margin="30,100,0,0"/>
                </Grid>

                <!-- Description Block -->
                <Border Background="White" CornerRadius="12" Margin="20,0" Padding="15" BorderBrush="#E0E0FF" BorderThickness="1">
                    <TextBlock Text="{x:Bind ViewModel.CurrentCommunity.Description, Mode=OneWay}" TextWrapping="Wrap" FontSize="15" Foreground="#444"/>
                </Border>

                <!-- Posts Area -->
                <ItemsControl ItemsSource="{x:Bind ViewModel.CommunityPosts, Mode=OneWay}" Margin="20,5">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:PostPreviewViewModel">
                            <views:PostPreviewForm Margin="0,0,0,15"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="Load More Posts"
                        Command="{x:Bind ViewModel.LoadBatchCommand}"
                        Visibility="{x:Bind GetVisibility(ViewModel.HasMorePosts), Mode=OneWay}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,30"
                        Padding="20,10"
                        Background="{x:Bind ViewModel.MainViewModel.VividThemeBrush, Mode=OneWay}" 
                        Foreground="White" CornerRadius="8"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>