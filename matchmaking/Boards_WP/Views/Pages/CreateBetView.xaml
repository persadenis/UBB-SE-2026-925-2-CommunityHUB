<Page
    x:Class="Boards_WP.Views.Pages.CreateBetView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F3F2FF">

    <ScrollViewer>
        <StackPanel 
                    Padding="40"
                    Spacing="20"
                    MaxWidth="600"
                    HorizontalAlignment="Left">

         
            <TextBlock Text="Create New Bet"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#1A1A2E"/>

            <TextBlock Text="A fee of 5 tokens has been deducted."
                       Foreground="Gray"
                       Margin="0,-15,0,0"/>


            <ComboBox Header="Target Community"
                      ItemsSource="{Binding Communities}"
                      SelectedItem="{Binding SelectedCommunity, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      HorizontalAlignment="Stretch"/>   


            <StackPanel Spacing="5">
                <TextBlock Text="Bet Type"
                           FontWeight="SemiBold"/>

                <RadioButton Content="Post"
             IsChecked="{Binding IsPost, Mode=TwoWay}"/>

                <RadioButton Content="Comment"
             Checked="Comment_Checked"/>
            </StackPanel>

          
            <TextBox Header="Expression"
                     Text="{Binding Expression, Mode=TwoWay}"
                     PlaceholderText="Enter the phrase..."/>

          
            <StackPanel Spacing="5">
                <TextBlock Text="Ending Time (Validation)"
                           FontWeight="SemiBold"/>

                <StackPanel Orientation="Horizontal"
                            Spacing="10">

                    <CalendarDatePicker Date="{Binding EndDate, Mode=TwoWay}"
                                        PlaceholderText="Pick Date"/>

                    <TimePicker Time="{Binding EndTime, Mode=TwoWay}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        Margin="0,20,0,0">

                <Button Content="Confirm &amp; Publish"
                        Command="{Binding CreateBetCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        Width="150"/>

                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Width="100"/>
            </StackPanel>

            
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="Red"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</Page>