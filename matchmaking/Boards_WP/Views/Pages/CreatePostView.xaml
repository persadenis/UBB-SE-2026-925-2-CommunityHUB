<Page
    x:Class="Boards_WP.Views.Pages.CreatePostView"
    x:Name="CreatePostPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Boards_WP.Data.Models"
    xmlns:helpers="using:Boards_WP.Helpers"
    Background="Transparent">

    <Grid Padding="40">
        <!-- Added Row Definitions to dock the buttons at the bottom -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />    <!-- Content Area -->
            <RowDefinition Height="Auto" /> <!-- Footer Area for Buttons -->
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- Left Column: Form Elements wrapped in ScrollViewer to prevent off-screen clipping -->
        <ScrollViewer Grid.Row="0" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,10,0">
            <!-- Removed Width="100%" and changed to HorizontalAlignment="Stretch" -->
            <StackPanel Spacing="15" MaxWidth="600" HorizontalAlignment="Stretch">
                <TextBlock Text="Create Post" 
                           FontSize="32" 
                           FontWeight="Bold"
                           Foreground="#4F4F4F" 
                           Margin="0,0,0,10"/>

                <TextBox x:Name="TitleInput" 
                         Text="{x:Bind ViewModel.PostTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Title" 
                         FontSize="18"
                         FontWeight="SemiBold" 
                         CornerRadius="8"/>

                <TextBox x:Name="DescriptionInput" 
                         Text="{x:Bind ViewModel.PostDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Text (optional)" 
                         AcceptsReturn="True" 
                         Height="200"
                         TextWrapping="Wrap" 
                         CornerRadius="8"/>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <!-- Updated ComboBox Design for better visibility -->
                    <ComboBox x:Name="CategorySelector" 
                        ItemsSource="{x:Bind ViewModel.AvailableCategories, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                        DisplayMemberPath="CategoryName"
                        PlaceholderText="Select Category" 
                        Width="200"
                        Background="Gray"
                        Foreground="Black"
                        BorderThickness="1"
                        BorderBrush="#CCCCCC"
                        CornerRadius="8">
                        <ComboBox.Resources>
                            <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="DarkGray"/>
                            <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="DarkGray"/>
                            <SolidColorBrush x:Key="ComboBoxForegroundPointerOver" Color="Black"/>
                            <SolidColorBrush x:Key="ComboBoxForegroundPressed" Color="Black"/>
                        </ComboBox.Resources>
                    </ComboBox>

                    <TextBox x:Name="TagsInput" 
                        Text="{x:Bind ViewModel.CurrentTagText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Write a tag name" 
                        Width="200"
                        CornerRadius="8"/>

                    <Button Content="Add Tag"
                        Command="{x:Bind ViewModel.AddTagCommand}"
                        Background="#6A67E1" Foreground="White" CornerRadius="8"/>
                </StackPanel>

                <ItemsControl ItemsSource="{x:Bind ViewModel.AddedTags, Mode=OneWay}" Margin="0,5,0,5">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Tag">
                            <Border CornerRadius="12" Padding="8,4" Background="{x:Bind helpers:ColorHelper.GetBrushForCategory(CategoryBelongingTo.CategoryID), Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="{x:Bind TagName, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    <Button Content="✕" 
                                            Command="{Binding ViewModel.RemoveTagCommand, ElementName=CreatePostPage}"
                                            CommandParameter="{x:Bind}"
                                            Background="Transparent" BorderThickness="0" Foreground="White" Padding="2" FontSize="10" MinWidth="15" MinHeight="15"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Right Column: Add Photo Element -->
        <Grid Grid.Row="0" Grid.Column="1" Margin="0,50,0,0" VerticalAlignment="Top">
            <Grid Height="200" CornerRadius="12" Background="#E0E0E0">
                <Border CornerRadius="12">
                    <Grid x:Name="PicturePreviewMask" Visibility="Collapsed">
                        <Rectangle RadiusX="12" RadiusY="12">
                            <Rectangle.Fill>
                                <ImageBrush x:Name="PicturePreviewBrush" Stretch="UniformToFill"/>
                            </Rectangle.Fill>
                        </Rectangle>
                    </Grid>
                </Border>

                <Button HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="ImagePicker_Click"
                        Background="#00000060"
                        CornerRadius="8"
                        Padding="14,8">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock x:Name="PictureIcon" Text="📷" FontSize="16"/>
                        <TextBlock Text="Add Photo" Foreground="White" FontSize="14"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>

        <!-- Footer Row: Action Buttons spanning across entire screen width at bottom right -->
        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" Spacing="15" HorizontalAlignment="Right" Margin="0,20,0,0">
            <!-- Updated Background/Foreground to be more readable and standard for Cancel actions -->
            <Button Content="Cancel" 
                    Command="{x:Bind ViewModel.CancelCommand}"
                    Background="Red"
                    Foreground="Black"
                    Padding="20,12"
                    CornerRadius="10"/>

            <Button Content="Upload Post" 
                    Command="{x:Bind ViewModel.UploadPostCommand}" 
                    Background="DarkGray" 
                    Foreground="Black" 
                    FontWeight="Bold"
                    Padding="40,12" 
                    CornerRadius="10"/>
        </StackPanel>
    </Grid>
</Page>