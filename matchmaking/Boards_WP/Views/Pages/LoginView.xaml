<Page
    x:Class="Boards_WP.Views.Pages.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Boards_WP.Views.Pages"
    mc:Ignorable="d">



    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#6A67E1" Offset="0.0" />
                <GradientStop Color="#C862AC" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350" Spacing="20">
            <TextBlock Text="WEAPONIZED PENGUINS" 
                       FontSize="24" FontWeight="Bold" Foreground="White" 
                       HorizontalAlignment="Center" CharacterSpacing="100"/>

            <Border Background="White" CornerRadius="15" Padding="30" 
                    BorderBrush="#E0E0FF" BorderThickness="1"
                    RequestedTheme="Light">
                <StackPanel Spacing="15">
                    <TextBlock Text="Welcome Back" FontSize="20" FontWeight="SemiBold" Foreground="#333"/>

                    <TextBox PlaceholderText="Email Address" 
                             Text="{x:Bind ViewModel.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Header="Email"/>

                    <PasswordBox x:Name="PassBox" 
                                 PlaceholderText="Password" 
                                 Header="Password"/>

                    <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" 
                               Foreground="Red" FontSize="12" TextWrapping="Wrap"
                               Visibility="{x:Bind StringToVis(ViewModel.ErrorMessage), Mode=OneWay}"/>

                    <Button Content="Login" 
                            Command="{x:Bind ViewModel.LoginCommand}"
                            CommandParameter="{Binding ElementName=PassBox}"
                            HorizontalAlignment="Stretch" 
                            Background="#6A67E1" Foreground="White" 
                            Height="45" CornerRadius="8" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>