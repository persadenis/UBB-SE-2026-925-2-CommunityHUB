<UserControl
    x:Class="Boards_WP.Views.PostPreviewForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Boards_WP.Data.Models"
    xmlns:viewmodels="using:Boards_WP.ViewModels">

    <Button Command="{x:Bind ViewModel.OpenPostCommand}"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            Padding="0"
            Background="Transparent"
            BorderThickness="0">

        <Button.Resources>
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent"/>
            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent"/>
        </Button.Resources>

        <Grid Background="White"
              CornerRadius="12"
              Padding="15"
              BorderBrush="#E0E0FF"
              BorderThickness="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Center"
                        Background="#F8F8FF" CornerRadius="8" Padding="4" BorderBrush="#E0E0FF" BorderThickness="1">

                <Button Content="▲" Command="{x:Bind ViewModel.UpvoteCommand, Mode=OneWay}" Foreground="#6B588C"
                    Background="Transparent" BorderThickness="0" HorizontalAlignment="Center">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#B09AD6"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#807099"/>
                    </Button.Resources>
                </Button>

                <TextBlock Text="{x:Bind ViewModel.PostData.Score, Mode=OneWay}" 
                    HorizontalAlignment="Center" FontWeight="Bold" 
                    Foreground="{x:Bind ViewModel.MainViewModel.VividThemeBrush, Mode=OneWay}"/>

                <Button Content="▼" Command="{x:Bind ViewModel.DownvoteCommand, Mode=OneWay}"  Foreground="#6B588C"
                        Background="Transparent" BorderThickness="0" HorizontalAlignment="Center">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#B09AD6"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#807099"/>
                    </Button.Resources>
                </Button>

                <TextBlock Text="{x:Bind ViewModel.VoteStatusText, Mode=OneWay}"
                    FontSize="10"
                    Foreground="#6B588C"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    TextWrapping="Wrap"
                    TextAlignment="Center"
                    Margin="0,5,0,0"/>
            </StackPanel>

         
            <StackPanel Grid.Column="1" Margin="15,0">

               
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.CommunityName, Mode=OneWay}" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{x:Bind ViewModel.AuthorUsername, Mode=OneWay}" FontSize="12" Foreground="Gray"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="{x:Bind ViewModel.FormattedDate, Mode=OneWay}"
                               FontSize="11" Foreground="Silver" VerticalAlignment="Top"/>
                </Grid>

                <TextBlock Text="{x:Bind ViewModel.PostData.Title, Mode=OneWay}"
                           FontSize="18" FontWeight="SemiBold" Margin="0,0,0,5" TextWrapping="Wrap"/>

                <TextBlock Text="{x:Bind ViewModel.DescriptionSnippet, Mode=OneWay}"
                           TextWrapping="Wrap" Foreground="#444"/>

                <Image Source="{x:Bind ViewModel.PostImageSource, Mode=OneWay}"
                       Visibility="{x:Bind ViewModel.PostImageVisibility, Mode=OneWay}"
                       MaxHeight="200"
                       Stretch="Uniform"
                       HorizontalAlignment="Stretch"
                       Margin="0,10,0,0"/>

            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Center">
                <Border BorderBrush="#E0E0FF" BorderThickness="1" CornerRadius="5" Padding="5">
                    <StackPanel>
                        <FontIcon Glyph="&#xE8BD;" FontSize="18" Foreground="{x:Bind ViewModel.MainViewModel.VividThemeBrush, Mode=OneWay}"/>
                        <TextBlock Text="{x:Bind ViewModel.PostData.CommentsNumber, Mode=OneWay}" HorizontalAlignment="Center" FontSize="10"/>
                    </StackPanel>
                </Border>
            </StackPanel>

        </Grid>
    </Button>
</UserControl>
