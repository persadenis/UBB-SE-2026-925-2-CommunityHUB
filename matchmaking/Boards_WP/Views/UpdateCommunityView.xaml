<Page
    x:Class="Boards_WP.Views.Pages.UpdateCommunityView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="transparent">

    <Grid Padding="40">
        <StackPanel Spacing="20" MaxWidth="800" HorizontalAlignment="Left">
            <TextBlock Text="Edit your Community" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="{x:Bind ViewModel.MainViewModel.VividThemeBrush, Mode=OneWay}"/>


            <Grid Height="160" CornerRadius="12" Background="#E0E0E0">
                <Border CornerRadius="12">
                    <Image x:Name="BannerPreview" Stretch="UniformToFill"/>
                </Border>
                <Button HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="BannerPicker_Click"
                        Background="#00000060"
                        CornerRadius="8"
                        Padding="14,8">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="🖼️" FontSize="16"/>
                        <TextBlock Text="Choose banner" Foreground="White" FontSize="14"/>
                    </StackPanel>
                </Button>
            </Grid>


            <StackPanel Orientation="Horizontal" Spacing="15">
                <Grid Width="60" Height="60">
                    <Ellipse Width="60" Height="60" Fill="#CBCBCB"/>
                    <Ellipse x:Name="PicturePreviewMask" Width="60" Height="60">
                        <Ellipse.Fill>
                            <ImageBrush x:Name="PicturePreviewBrush" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Button Width="60"
                            Height="60"
                            CornerRadius="30"
                            Background="Transparent"
                            Click="PicturePicker_Click"
                            ToolTipService.ToolTip="Choose community picture">
                        <TextBlock x:Name="PictureIcon" Text="📷" FontSize="22"/>
                    </Button>
                </Grid>

                <TextBox Text="{x:Bind ViewModel.CommunityName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Pick a name..." 
                         FontSize="24" 
                         Width="400" 
                         BorderThickness="0,0,0,1" 
                         Background="Transparent"/>
            </StackPanel>

            <TextBox Text="{x:Bind ViewModel.CommunityDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Add a description..." 
                     AcceptsReturn="True" 
                     Height="150" 
                     TextWrapping="Wrap" 
                     CornerRadius="8"/>

            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       Foreground="Red"
                       Visibility="{x:Bind ViewModel.HasError, Mode=OneWay}"/>

            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <Button Content="Cancel" 
                        Command="{x:Bind ViewModel.CancelCommand}"
                        Background="Transparent"
                        Foreground="Gray"
                        Padding="20,12"
                        CornerRadius="10"/>

                <Button Content="Update the community" 
                        Command="{x:Bind ViewModel.UpdateCommunityCommand}"
                        Background="{x:Bind ViewModel.MainViewModel.MidThemeBrush, Mode=OneWay}" 
                        Foreground="White" 
                        FontWeight="Bold"
                        Padding="30,12" 
                        CornerRadius="10"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>